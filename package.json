{
  "name": "ssh-manager",
  "version": "1.0.0",
  "description": "Interactive CLI tool for managing SSH credentials",
  "type": "module",
  "bin": {
    "ssh-manager": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile ssh-manager",
    "build:mac-arm": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile dist/ssh-manager-darwin-arm64",
    "build:mac-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile dist/ssh-manager-darwin-x64",
    "build:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile dist/ssh-manager-linux-x64",
    "build:linux-arm": "bun build src/index.ts --compile --target=bun-linux-arm64 --outfile dist/ssh-manager-linux-arm64"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
